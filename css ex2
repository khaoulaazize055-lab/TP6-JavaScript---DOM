body {
    font-family: Arial;
    text-align: center;
    background-color: #f5f5f5;
}

h1 {
    color: #333;
}

input {
    padding: 10px;
    width: 200px;
}

button {
    padding: 10px;
    margin-left: 5px;
    cursor: pointer;
}

ul {
    list-style: none;
    padding: 0;
}

li {
    background: white;
    margin: 10px auto;
    padding: 10px;
    width: 300px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 5px;
}

.done {
    text-decoration: line-through;
    color: gray;
}
